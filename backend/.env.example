# Bu faylni nusxalab `.env` yarating:  cp .env.example .env
# .env fayli git'ga qo'shilmaydi (.gitignore da bor).

# Yangi SECRET_KEY generatsiya qilish:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-generate-a-new-secret-key

# Lokal ishlab chiqishda True, productionda False
DEBUG=True

# Vergul bilan ajratilgan hostlar
ALLOWED_HOSTS=localhost,127.0.0.1

# Frontend manzillari (CORS)
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173


# ===== AI yordamchi (ixtiyoriy) =====
# OpenAI-mos API kaliti. Bepul variantlar: Groq, OpenRouter.
# Masalan OpenAI: AI_BASE_URL=https://api.openai.com/v1 , AI_MODEL=gpt-4o-mini
# Masalan Groq:   AI_BASE_URL=https://api.groq.com/openai/v1 , AI_MODEL=llama-3.3-70b-versatile
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
